# Fish-Agent 环境变量配置模板
# 复制本文件为 .env 并填写实际值

# 项目工作区路径；留空时自动使用当前源码根目录
FISH_AGENT_WORKSPACE=

# OpenAI-compatible 大模型接口
OPENAI_API_KEY=
OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1

# FishFreshNetV1 模型推理服务地址
FISHFRESHNET_API_URL=https://your-fishfreshnet-api.example

# Grad-CAM 可视化服务地址（通常与模型服务相同）
MODEL_SERVICE_URL=https://your-fishfreshnet-api.example

# FishFreshNetV1 权重文件路径
FISHFRESHNET_MODEL_PATH=

# CORS 允许的来源（逗号分隔，留空则允许所有来源）
CORS_ORIGINS=

# 日志级别：DEBUG / INFO / WARNING / ERROR
FISH_AGENT_LOG_LEVEL=INFO
